# SQLite (relative to project root)
DATABASE_URL="file:./dev.db"

# Logging: trace | debug | info | warn | error | fatal (pino)
# LOG_LEVEL=info

# Seed: unset or non-zero = wipe platform tables (approvals, audit, lifecycle, templates,
# gates, roles, app settings) then recreate. Use 0 for idempotent upserts only (preserves
# approvals / audit rows you created locally).
# SEED_FULL_GLOBAL_RESET=0

# Pre-release: skip vault/SQLite backup (default runs backup after validate)
# SKIP_BACKUP=1
