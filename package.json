{
  "name": "lifecycle-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache",
    "rebuild": "npm run clean && npm run build",
    "dev": "cross-env NEXT_DISABLE_DEV_OVERLAY=1 next dev -p 3001",
    "dev:clean": "npm run clean && npm run db:generate && cross-env NEXT_DISABLE_DEV_OVERLAY=1 next dev -p 3001",
    "typecheck": "tsc --noEmit",
    "check-templates": "tsx scripts/check-templates.ts --strict-forms-expected",
    "phase-model-check": "tsx scripts/phase-model-check.ts",
    "db-phase-sanity": "tsx scripts/db-phase-sanity.ts",
    "repair-workspace-phases": "tsx scripts/repair-workspace-phases.ts",
    "build": "tsx scripts/next-build-reliable.ts",
    "build:direct": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 prisma generate && next build && tsx scripts/assert-no-next-dev-ui-in-prod-bundle.ts",
    "assert:prod-bundle": "tsx scripts/assert-no-next-dev-ui-in-prod-bundle.ts",
    "prestart": "tsx scripts/assert-next-build.ts",
    "start": "node scripts/next-start.mjs",
    "lint": "eslint",
    "validate": "npm run lint && npm run typecheck && npm run build",
    "seed-smoke": "tsx scripts/seed-smoke.ts",
    "data-integrity-check": "tsx scripts/data-integrity-check.ts",
    "route-smoke": "tsx scripts/route-smoke.ts",
    "ci-route-smoke": "tsx scripts/ci-route-smoke.ts",
    "release-snapshot": "tsx scripts/release-snapshot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "cross-env CI=1 playwright test",
    "test:e2e:install": "playwright install chromium",
    "ci:e2e": "npm run build && cross-env CI=1 E2E_DATABASE_URL=file:./e2e.db E2E_USE_PROD_SERVER=1 playwright test",
    "seed:e2e-lifecycle": "tsx e2e/support/run-seed.ts",
    "prepare": "husky || true",
    "pre-release": "tsx scripts/pre-release.ts",
    "pre-release:fast": "cross-env PRE_RELEASE_FAST=1 tsx scripts/pre-release.ts",
    "ci": "tsx scripts/ci-prep.ts && npm run validate && npm run check-templates && npm run phase-model-check && npm run test:cov && cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 npx prisma migrate deploy && npm run db-phase-sanity && npm run seed && npm run seed-smoke && npm run data-integrity-check && npm run restore-smoke && npm run ci:e2e",
    "db:generate": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 prisma generate",
    "db:migrate": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 prisma migrate dev",
    "db:push": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 prisma db push",
    "db:studio": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 prisma studio",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=1 prisma generate",
    "restore-smoke": "tsx scripts/restore-smoke.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.14.0",
    "next": "15.5.18",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
