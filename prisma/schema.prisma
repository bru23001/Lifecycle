// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite stores Prisma `Json` as TEXT at rest. Hand-edited migrations must use quoted
// defaults (`'{}'`, `'[]'`) — not `DEFAULT {}` / raw JSONB defaults — or apply will fail.
// Do not edit a migration folder after deploy (checksum recorded in `_prisma_migrations`).

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("Project Owner")
  initials  String   @default("AD")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedProjects        Project[]         @relation("ProjectOwner")
  submittedApprovals   Approval[]        @relation("ApprovalSubmitter")
  approvalComments     ApprovalComment[] @relation("ApprovalCommentAuthor")
  auditEntries         AuditEntry[]      @relation("AuditActor")
  wizardCollaborationComments WizardCollaborationComment[] @relation("WizardCommentAuthor")
  artifactReviewAssignmentsAsAssignee ArtifactReviewRequest[] @relation("ReviewRequestAssignee")
  artifactReviewAssignmentsAsAssigner ArtifactReviewRequest[] @relation("ReviewRequestAssigner")
  evidenceComments                  EvidenceComment[]        @relation("EvidenceCommentAuthor")
}

model Project {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  ownerId       String?
  owner         User?          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  /** Evidence vault root folder: `PRD-XXX` or `IDEA-NNNN` (Appendix A / plan). */
  vaultFolder   String         @default("IDEA-0001")
  /**
   * Workspace milestone index 1–14 (aligned with `WORKSPACE_PHASES` in lib/workspacePhases.ts).
   * See `lib/phaseTransitions.ts` for gate exits.
   */
  currentPhase  Int            @default(1)
  /** Phase 7 applicability toggles: data (ERD), apis (API contract), ui (UXD), modules, blueprint */
  applicabilityJson Json       @default("{}")
  /** Per workspace phase (1–14) editable metadata: owner override, dates, notes, priority, risk, contributors. */
  workspacePhaseDetailsJson Json @default("{}")
  /** Confirmed complexity for G4 (align `23. Project Complexity Levels.md`). */
  complexityLevel   String?
  /** STD-ENG-001 / Namespace M notes for G6. */
  namingConformanceNote String?
  /** Initial test setup evidence for G6. */
  initialTestSetupNote    String?
  /** When set, project is hidden from the active projects list but deep links may still resolve. */
  archivedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  artifacts     Artifact[]
  gateDecisions   GateDecision[]
  requirements  Requirement[]
  features      Feature[]
  traceLinks    TraceLink[]
  evidenceItems   EvidenceItem[]
  applicabilityRecords ApplicabilityRecord[]
  approvals       Approval[]
  auditEntries    AuditEntry[]
  gateApproverAssignments GateApproverAssignment[]
  wizardCollaborationComments WizardCollaborationComment[]
  artifactReviewRequests ArtifactReviewRequest[]
  traceabilityReportSchedules TraceabilityReportSchedule[]

  @@index([ownerId])
}

model Requirement {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /** CRS-001, SRS-FR-001, SRS-NFR-001, NFR-001 */
  localId             String
  kind                String   // CRS | SRS_FR | SRS_NFR | NFR
  title               String
  body                String   @default("")
  verificationMethod  String?
  status              String   @default("Draft")
  version             Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([projectId, localId])
  @@index([projectId, kind])
}

model Feature {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  localId     String   // FEAT-001
  title       String
  description String   @default("")
  priority    String?
  status      String   @default("Draft")
  scopeStatus String   @default("InScope")
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, localId])
}

model TraceLink {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromKind  String   // requirement | feature | artifact
  fromId    String
  toKind    String
  toId      String
  relation  String   // informs | derives | validates | implements | tests | satisfies | verifies | evidences | depends_on | blocks
  rationale String   @default("")
  /** low | medium | high */
  confidence        String    @default("medium")
  evidenceReference String    @default("")
  verificationNote  String    @default("")
  lastVerifiedAt    DateTime?
  deletedAt         DateTime?
  createdByUserId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, fromKind, fromId])
  @@index([projectId, toKind, toId])
  @@index([projectId, deletedAt])
}

model TraceabilityReportSchedule {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportName          String
  /** daily | weekly | monthly | gate_submission */
  frequency           String
  /** JSON array of email strings */
  recipientsJson      String   @default("[]")
  /** csv | json | html_print | zip */
  format              String   @default("html_print")
  includeGapsOnly     Boolean  @default(false)
  includeFullMatrix   Boolean  @default(true)
  active              Boolean  @default(true)
  createdByUserId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([projectId])
}

model GateDecision {
  id                   String   @id @default(cuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gateId               String
  decision             String
  authorityName        String
  authorityRole        String
  nextAction           String
  /** Whether `evaluateGate` passed at submit time (advance decisions require true). */
  evidencePassSnapshot Boolean
  createdAt            DateTime @default(now())

  @@index([projectId, gateId])
}

/**
 * Pre-decision approver assignment for a gate review. Distinct from
 * `Approval` (which is artifact-scoped) and `GateDecision` (immutable record
 * of the rendered decision). Captures snapshot fields so the audit trail
 * stays intact even if the underlying `User` row is later deactivated.
 *
 * CYBERCUBE 3.3 (Data Classification): CON-class — `approverName`/`approverRole`
 * are display fields; never log raw values outside structured audit entries.
 */
model GateApproverAssignment {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gateId        String
  /** Soft reference (no FK) to `User.id`. May be null when assigning by role only. */
  userId        String?
  approverName  String
  approverRole  String
  dueAt         DateTime?
  assignedById  String?
  createdAt     DateTime @default(now())

  @@index([projectId, gateId])
}

model Artifact {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId   String
  localId      String
  version      Int
  status       String   @default("Draft")
  dataJson     Json
  markdownPath String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  evidenceLinks EvidenceArtifactLink[]
  approvals    Approval[]

  @@unique([projectId, templateId, localId, version])
}

/** Threaded comments on a template wizard context (project + template; optional field/section anchor). */
model WizardCollaborationComment {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId  String
  artifactId  String?
  sectionId   String?
  fieldName   String?
  authorId    String?
  author      User?    @relation("WizardCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body        String
  resolved    Boolean  @default(false)
  visibility  String   @default("internal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, templateId, createdAt])
}

/** Reviewer assignment request from the template wizard (snapshot fields; not the approval queue). */
model ArtifactReviewRequest {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId     String
  artifactId     String?
  assigneeUserId String?
  assignee       User?     @relation("ReviewRequestAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  assigneeName   String
  assigneeRole   String
  dueAt          DateTime?
  reviewScope    String    @default("full")
  instructions   String?
  assignedById   String?
  assignedBy     User?     @relation("ReviewRequestAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())

  @@index([projectId, templateId])
}

/** Gate or artifact review queue item (distinct from immutable `GateDecision` record). */
model Approval {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvalType   String // gate_review | artifact_review
  gateId         String?
  artifactId     String?
  artifact       Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  status         String   @default("pending") // pending | in_review | approved | changes_requested | rejected | superseded
  priority       String   @default("medium")
  submittedById  String?
  submittedBy    User?    @relation("ApprovalSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  dueAt          DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  comments       ApprovalComment[]

  @@index([projectId, status])
  @@index([artifactId])
}

model ApprovalComment {
  id         String   @id @default(cuid())
  approvalId String
  approval   Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation("ApprovalCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body       String
  createdAt  DateTime @default(now())

  @@index([approvalId, createdAt])
}

model AuditEntry {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String
  subjectKind String
  subjectId   String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([subjectKind, subjectId])
}

/** One row per workspace milestone (1–14); drives Settings → Lifecycle Configuration. */
model LifecyclePhaseConfig {
  id                   String   @id @default(cuid())
  phaseNumber          Int      @unique
  name                 String
  description          String   @default("")
  keyDeliverablesJson       Json     @default("[]")
  requiredArtifactIdsJson   Json     @default("[]")
  status               String   @default("active") // active | inactive | draft
  updatedAt            DateTime @updatedAt
}

/** Template catalog row; drives Settings → Template Registry. */
model TemplateRegistryEntry {
  id             String   @id @default(cuid())
  templateCode   String   @unique
  name           String
  phaseNumber    Int
  outputType     String   @default("both") // markdown | json | both
  required       Boolean  @default(true)
  schemaVersion  String   @default("1.0")
  status         String   @default("active") // active | draft | deprecated | archived
  updatedAt      DateTime @updatedAt
}

/** Gate rule row; drives Settings → Gate Rules. */
model GateRuleConfig {
  id                          String   @id @default(cuid())
  gateCode                    String   @unique
  gateName                    String
  relatedPhaseNumber          Int
  requiredInputIdsJson        Json     @default("[]")
  requiredEvidenceCount       Int      @default(0)
  requiredApproverRolesJson   Json     @default("[]")
  decisionRule                String   @default("single_approver") // single_approver | majority | unanimous | role_based
  unlocksPhaseNumber          Int?
  status                      String   @default("active") // active | draft | inactive
  updatedAt                   DateTime @updatedAt
}

/** RBAC matrix row; drives Settings → Roles / Permissions. */
model RoleConfig {
  id              String   @id @default(cuid())
  roleId          String   @unique
  roleName        String
  description     String   @default("")
  permissionsJson Json     @default("[]")
  systemRole      Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

/** Key-value app settings (export package rules, local storage prefs, etc.). */
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/** External evidence file or reference attached to a project (Evidence Center). */
model EvidenceItem {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidenceCode        String
  name                String
  description         String   @default("")
  evidenceType        String
  phaseNumber         Int?
  gateCode            String?
  classification      String   @default("internal")
  status              String   @default("linked")
  completenessPercent Int      @default(100)
  fileTypeLabel       String   @default("Document")
  fileSizeBytes       Int?
  source              String?
  retentionPolicyLabel String?
  checksum            String?
  tagsJson            Json     @default("[]")
  notes               String?
  uploadedByName      String   @default("Local User")
  previewHref         String?
  downloadHref        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  artifactLinks       EvidenceArtifactLink[]
  gateLinks           EvidenceGateLink[]
  phaseLinks          EvidencePhaseLink[]
  comments            EvidenceComment[]

  @@unique([projectId, evidenceCode])
  @@index([projectId, gateCode])
}

model EvidenceGateLink {
  evidenceId String
  gateCode   String
  evidence   EvidenceItem @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@id([evidenceId, gateCode])
  @@index([gateCode])
}

model EvidencePhaseLink {
  evidenceId   String
  phaseNumber  Int
  evidence     EvidenceItem @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@id([evidenceId, phaseNumber])
  @@index([phaseNumber])
}

/** Threaded discussion on an evidence item (Evidence Center). */
model EvidenceComment {
  id            String       @id @default(cuid())
  evidenceId    String
  evidence      EvidenceItem @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  authorId      String?
  author        User?        @relation("EvidenceCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorName    String       @default("User")
  body          String       @default("")
  visibility    String       @default("project")
  mentionsJson  Json         @default("[]")
  attachmentRef String?
  resolved      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([evidenceId, createdAt])
}

model EvidenceArtifactLink {
  evidenceId String
  evidence   EvidenceItem @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  artifactId String
  artifact   Artifact     @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@id([evidenceId, artifactId])
  @@index([artifactId])
}

/**
 * Structured applicability dimension or standard reference (dual-read with applicabilityJson).
 * Keys: data | apis | ui | modules | blueprint | or STD-* code.
 */
model ApplicabilityRecord {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key        String
  applies    Boolean  @default(true)
  rationale  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([projectId, key])
  @@index([projectId])
}
